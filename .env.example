# 이 파일은 "어떤 비밀 값이 필요한지 이름만" 적어두는 견본이에요.
# 실제 값은 여기 적지 말고, 아래 두 곳 중 하나에 등록하세요:
#   - GitHub 레포 → Settings → Secrets and variables → Actions
#   - 또는 Vercel 프로젝트 → Settings → Environment Variables
#
# 이 .env.example 은 깃허브에 올려도 됩니다 (값이 없으니까).
# 실제 값이 든 .env 파일은 .gitignore 가 자동으로 막아줘요. 절대 올리지 마세요.
#
# 아래는 예시예요. 본인 프로젝트에 필요한 것만 남기고 이름을 바꿔 쓰세요.

# 예) 외부 서비스 토큰
# DISCORD_TOKEN=
# NOTION_TOKEN=
# OPENAI_API_KEY=

# 예) 데이터베이스 접속 정보
# DATABASE_URL=

# Supabase 브라우저 연결. publishable key만 사용하고 service_role key는 넣지 마세요.
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# 선택: Google 로그인. Supabase Auth provider와 /auth/callback 허용을 마친 뒤에만 1로 켭니다.
# NEXT_PUBLIC_GOOGLE_LOGIN=0

# 선택: GA4 Measurement ID. 비워두면 이벤트는 브라우저 localStorage에만 기록됩니다.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Kakao JavaScript 키. Kakao Developers에 실제 서비스 도메인도 JavaScript SDK 도메인으로 등록하세요.
# NEXT_PUBLIC_KAKAO_JAVASCRIPT_KEY=

# 로컬에서 카카오톡 공유를 시험할 때 수신자에게 보낼 공개 서비스 주소입니다.
# NEXT_PUBLIC_SITE_URL=https://bfd-seven.vercel.app
