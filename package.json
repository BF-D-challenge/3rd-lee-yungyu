{
  "name": "oneul-haebolkka",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:e2e": "npm run build && npm run start -- --hostname 127.0.0.1 --port 3100",
    "lint": "eslint src tests --ext .js,.ts,.tsx --max-warnings=0",
    "typecheck": "tsc --noEmit --project tsconfig.typecheck.json",
    "test": "npm run typecheck && npm run test:unit",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:integration": "npm run test:unit && npm run test:e2e",
    "quality:cards": "node scripts/rollout/validate-golden.mjs public/data/golden.json && node scripts/rollout/check-golden-visible-smells.mjs && node scripts/rollout/audit-golden-human-fit.mjs --minScore 72 --label latest && node scripts/rollout/experiment-mobile-card-pairing.mjs --runs 20000"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-slot": "^1.1.1",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.107.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "es-toolkit": "^1.42.0",
    "framer-motion": "^12.41.0",
    "lucide-react": "^1.21.0",
    "next": "15.5.20",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.67.0",
    "tailwind-merge": "^2.6.0",
    "ts-pattern": "^5.9.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.22",
    "eslint": "^8",
    "eslint-config-next": "15.5.20",
    "postcss": "8.5.16",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^3.2.7"
  },
  "overrides": {
    "postcss": "8.5.16"
  }
}
